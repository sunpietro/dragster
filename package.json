{
  "name": "dragsterjs",
  "version": "2.1.0",
  "description": "Tiny vanilla JS plugin that enables drag'n'drop interactions to a user of your website",
  "main": "dragster.js",
  "types": "dragster.d.ts",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "generate-modules": "node module-generator.js",
    "minify": "uglifyjs dragster.js --mangle --compress --comments --output dragster.min.js",
    "gzip": "gzip -c dragster.min.js > dragster.min.js.gz",
    "lint": "eslint .",
    "prepare": "husky",
    "release": "pnpm test:headless && pnpm generate-modules && pnpm minify && pnpm gzip",
    "test": "npx kill-port 8370; pnpm serve & pnpm exec cypress open",
    "test:headless": "npx kill-port 8370; node_modules/.bin/http-server . -p 8370 & npx wait-on http://127.0.0.1:8370 && pnpm exec cypress run; npx kill-port 8370",
    "serve": "pnpm exec http-server . -p 8370"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sunpietro/dragster.git"
  },
  "keywords": [
    "javascript",
    "drag",
    "drop"
  ],
  "author": "Piotr Nalepa",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sunpietro/dragster/issues"
  },
  "homepage": "https://github.com/sunpietro/dragster",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/cypress": "^10.1.3",
    "cypress": "^15.14.2",
    "cypress-mcp": "^0.1.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "uglify-js": "^3.19.3"
  },
  "lint-staged": {
    "*.js": "pnpm lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["cypress"]
  }
}
